<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indie Games</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #8A2BE2;">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <img src="/imgs/logo_olho.png" alt="Olho" class="Olho">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Início</a>
                    </li>
                    <li class="nav-item-dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Sobre os Jogos
                        </a>
                        <ul class="dropdown-menu">
                        <% jogos.forEach(jogo => { %>
                            <li><a class="dropdown-item" href="/info_jogo/<%= jogo.id %>"><%= jogo.nome %></a></li>
                        <% }) %>
                </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/personagens">Personagens</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/premiacoes">Premiações</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>